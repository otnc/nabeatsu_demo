{
  "name": "nabeatsu.js",
  "version": "3.1.0",
  "description": "ナベアツ判定・変換ライブラリ",
  "type": "module",
  "main": "./dist/nabeatsu.cjs",
  "module": "./dist/nabeatsu.mjs",
  "types": "./dist/nabeatsu.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/nabeatsu.d.mts",
        "default": "./dist/nabeatsu.mjs"
      },
      "require": {
        "types": "./dist/nabeatsu.d.cts",
        "default": "./dist/nabeatsu.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/otnc/nabeatsu_demo.git"
  },
  "homepage": "https://github.com/otnc/nabeatsu_demo#readme",
  "bugs": {
    "url": "https://github.com/otnc/nabeatsu_demo/issues"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nabeatsu",
    "aho",
    "japanese"
  ],
  "author": "otoneko.",
  "license": "MIT",
  "dependencies": {
    "@geolonia/japanese-numeral": "^1.0.2",
    "jaconv": "^1.1.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "tsdown": "^0.22.7",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
